PORT=3000
# Local: redis://localhost:6379
# Cloud (TLS): rediss://<user>:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:5173
SESSION_TTL=1800
NODE_ENV=development

# Stream + consumer reliability
EVENTS_STREAM_MAXLEN=10000
PROFILE_CONSUMER_GROUP=profile-builders
PROFILE_CONSUMER_NAME=profile-consumer-1
PROFILE_CONSUMER_BLOCK_MS=5000
PROFILE_CONSUMER_BATCH_SIZE=50
PROFILE_CONSUMER_RECLAIM_IDLE_MS=60000
PROFILE_CONSUMER_RECLAIM_BATCH_SIZE=50
